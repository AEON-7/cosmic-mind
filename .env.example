# =============================================================================
# Cosmic Mind / SecondBrain Configuration
# Copy to .env and customize: cp .env.example .env && chmod 600 .env
# =============================================================================

# --- Site Domains ---
# Internal site (full vault, behind auth)
INTERNAL_DOMAIN=brain.lab.example.com

# External/public site
EXTERNAL_DOMAIN=example.com

# --- Site Branding ---
SITE_TITLE_INTERNAL=Second Brain
SITE_TITLE_EXTERNAL=Cosmic Mind

# --- Build Settings ---
BUILDS_TO_KEEP=5
WATCH_INTERVAL=60
